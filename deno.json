{
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window", "ES2023"]
  },
  "fmt": {
    "exclude": ["**/*"]
  },
  "lint": {
    "exclude": ["**/*"]
  },
  "tasks": {
    "dev": "deno run --sloppy-imports --allow-read --allow-write --allow-env --allow-sys --allow-run src/cli/main.ts",
    "check": "deno check --sloppy-imports src/cli/main.ts",
    "compile": "deno compile --no-check --sloppy-imports --allow-read --allow-write --allow-env --allow-sys --allow-run --output dist/bin/phax src/cli/main.ts"
  },
  "allowScripts": {
    "allow": [
      "npm:@parcel/watcher@2.5.6",
      "npm:msgpackr-extract@3.0.4",
      "npm:esbuild@0.21.5",
      "npm:esbuild@0.28.1",
      "npm:fsevents@2.3.3"
    ]
  }
}
