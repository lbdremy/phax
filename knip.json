{
  "entry": [
    "src/schemas/*.ts",
    "src/domain/*.ts",
    "src/ports/*.ts",
    "src/infra/*.ts",
    "src/infra/fakes/*.ts",
    "src/app/*.ts",
    "tests/**/*.test.ts",
    "tests/type/*.ts"
  ],
  "project": ["src/**/*.ts", "tests/**/*.ts"],
  "ignoreDependencies": ["@effect/platform", "@effect/platform-node"],
  "ignoreFiles": ["tests/e2e/fixtures/**"]
}
