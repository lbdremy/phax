// Generated from the Commander.js program tree — do not edit by hand.
// Regenerate with: pnpm gen:usage-spec
//
// Commander (src/cli/) is the source of truth for commands, flags, and
// arguments. phax.usage.kdl is a derived shareable CLI contract.

name "phax"
bin "phax"
version "0.4.0"
license "Apache-2.0"
min_usage_version "1.0.0"
about "Drive AI Coding agent through isolated, gated phases"

flag "--verbose" {
    global #true
    help "Print human-readable progress and system events"
}
flag "--trace" {
    global #true
    help "Write structured JSONL trace events to the run folder"
}
flag "--usage" {
    global #true
    help "Print the phax.usage.kdl CLI spec and exit"
}
flag "--usage-format" {
    global #true
    arg "<format>"
    default "kdl"
    help "Format for --usage output: kdl (default, no external dependency) or json (requires the usage CLI)"
}

complete "short-name" run="phax ls --complete" descriptions=#true

cmd "validate" {
    help "Validate phax.json and its user overlays without any side effects; pass --plan to also validate a phax-plan.json"
    flag "--plan" {
        arg "<path>"
        help "Also validate a phax-plan.json at this path"
    }
}

cmd "unlock" {
    help "Remove a stale run lock; use --force to remove any lock"
    arg "<short-name>" {
        help "Run short name, e.g. usage-cli"
    }
    flag "--force" {
        help "Remove the lock regardless of staleness"
    }
}

cmd "extract-plan" {
    help "Extract phax-plan.json from a plan.md by calling Claude Code headlessly"
    flag "--plan-md" {
        arg "<path>"
        required #true
        help "Path to the plan.md file to extract from"
    }
    flag "--out" {
        arg "<path>"
        required #true
        help "Output path for phax-plan.json"
    }
    flag "--force" {
        help "Overwrite existing output file (blocked if the run is actively locked)"
    }
    flag "--model" {
        arg "<model>"
        help "Claude model to use (overrides phax.json agent.extractPlan.model)"
    }
    flag "--effort" {
        arg "<effort>"
        help "Effort level (low|medium|high, overrides phax.json agent.extractPlan.effort)"
    }
    flag "--refresh" {
        help "Re-extract even if a cached extraction exists (overwrites cache entry)"
    }
}

cmd "enter" {
    help "Resume the final phase's agent session interactively"
    long_help "Attaches to the kept-open agent session in the final worktree, so you can review the agent's work, ask follow-up questions, or apply manual fixes interactively."
    example "phax enter usage-cli"
    arg "<short-name>" {
        help "Run short name, e.g. usage-cli"
    }
}

cmd "enter-phase" {
    help "Resume a specific phase's agent session interactively"
    long_help "Attaches to the agent session for a specific phase worktree. Useful for inspecting intermediate state or debugging a phase that has not yet been committed to main."
    example "phax enter-phase usage-cli phase-02"
    arg "<short-name>" {
        help "Run short name, e.g. usage-cli"
    }
    arg "<phase-id>" {
        help "Phase identifier, e.g. phase-02"
    }
}

cmd "session-info" {
    help "Print session diagnostics for a run (state, phase, worktree, session id)"
    long_help "Prints diagnostic information about a run: its current state, active phase, worktree path, and agent session id. Read-only — no side effects."
    example "phax session-info usage-cli"
    example "phax session-info usage-cli --debug"
    arg "<short-name>" {
        help "Run short name, e.g. usage-cli"
    }
    flag "--debug" {
        help "Dump raw binding and model-resolution metadata"
    }
}

cmd "shell" {
    help "Open a shell in the final worktree"
    long_help "Opens an interactive shell in the final worktree. Useful for manually inspecting files, running tests, or executing commands outside the agent session."
    example "phax shell usage-cli"
    arg "<short-name>" {
        help "Run short name, e.g. usage-cli"
    }
}

cmd "path" {
    help "Print the final worktree path (script-friendly, one line)"
    long_help "Prints the absolute path to the final worktree on a single line. Useful in scripts: cd $(phax path my-run) or for piping to other tools."
    example "phax path usage-cli"
    example "cd $(phax path usage-cli)"
    arg "<short-name>" {
        help "Run short name, e.g. usage-cli"
    }
}

cmd "open" {
    help "Open the final worktree in the configured editor"
    long_help "Opens the final worktree in the editor configured in phax.json (or the EDITOR environment variable). Equivalent to running your editor with the worktree path as an argument."
    example "phax open usage-cli"
    arg "<short-name>" {
        help "Run short name, e.g. usage-cli"
    }
}

cmd "ls" {
    help "List runs from the registry"
    long_help "Lists runs from the local registry (~/.phax/runs/). With no filter flags, shows all runs. Use status filters to narrow output: --active (created or running), --failed, --review-open (awaiting human review), or --archived. Use --json for machine-readable output."
    example "phax ls"
    example "phax ls --review-open"
    example "phax ls --failed --json"
    flag "--active" {
        help "Show only active runs (created or running)"
    }
    flag "--failed" {
        help "Show only failed runs"
    }
    flag "--review-open" {
        help "Show only review_open runs"
    }
    flag "--archived" {
        help "Show only archived runs"
    }
    flag "--json" {
        help "Output as JSON"
    }
    flag "--complete" {
        help "Print run short-names for shell completion"
    }
}

cmd "archive" {
    help "Archive a completed or review_open run"
    long_help "Archives a run by removing its worktrees and marking it archived in the registry. Without --force, fails when the final worktree has uncommitted changes.\n\nSide effects: deletes worktrees from the filesystem, updates ~/.phax/runs/."
    example "phax archive usage-cli"
    example "phax archive usage-cli --force"
    arg "<short-name>" {
        help "Run short name, e.g. usage-cli"
    }
    flag "--force" {
        help "Archive even if the final worktree has uncommitted changes"
    }
}

cmd "run" {
    help "Extract a plan from plan.md and run all phases, or preview with --dry-run"
    long_help "Extracts a plan from the plan.md given by --plan, creates a run entry in the registry, and executes each phase sequentially in its own Git worktree using the configured AI agent. Each phase runs a gate profile after execution; the final phase worktree stays open for human review.\n\nExtraction results are cached by content hash under ~/.phax/cache/plans/; a repeated run of the same plan.md reuses the cached extraction without calling the LLM again. Use --refresh to force a fresh extraction.\n\nSide effects: creates worktrees, commits files, writes to ~/.phax/runs/."
    example "phax run --plan plan.md"
    example "phax run my-feature --plan plan.md"
    example "phax run --plan plan.md --dry-run"
    example "phax run --plan plan.md --refresh"
    arg "[short-name]" {
        help "Run short name, e.g. usage-cli"
    }
    flag "--plan" {
        arg "<path>"
        required #true
        help "Path to the plan.md file to extract from"
    }
    flag "--allow-dirty" {
        help "Allow starting when the working tree is dirty"
    }
    flag "--provider-priority" {
        arg "<list>"
        help "Comma-separated provider priority override (e.g. mistral-vibe,claude-code)"
    }
    flag "--dry-run" {
        help "Preview only — extracts the plan but performs no run actions"
    }
    flag "--security" {
        arg "<mode>"
        help "Security mode override (secure|unsafe|isolated, overrides config default)"
    }
    flag "--refresh" {
        help "Re-extract the plan even if a cached extraction exists"
    }
}

cmd "review-handoff" {
    help "Regenerate review-handoff.md and global file reconciliation for a review_open run"
    arg "<short-name>" {
        help "Run short name, e.g. usage-cli"
    }
    flag "--allow-partial" {
        help "Generate a partial document when some phase artifacts are missing"
    }
}

cmd "publish-pr" {
    help "Push the final branch and create (or reuse) a GitHub PR for a review_open run"
    long_help "Pushes the final worktree branch to the GitHub remote and creates a pull request, or reuses an existing PR for the same branch. Requires a GitHub remote and gh CLI authentication.\n\nSide effects: git push to remote, GitHub API call to create or update a pull request."
    example "phax publish-pr usage-cli"
    arg "<short-name>" {
        help "Run short name, e.g. usage-cli"
    }
}

cmd "review-compliance" {
    help "Run a non-mutating plan-compliance review for a review_open run"
    long_help "Runs a non-mutating plan-compliance review by invoking the AI agent with the run's handoff artifacts and the original plan. Does not modify the worktree, registry, or any files.\n\nSide effects: spawns a short-lived AI agent session (network I/O); no filesystem mutations."
    example "phax review-compliance usage-cli"
    arg "<short-name>" {
        help "Run short name, e.g. usage-cli"
    }
}

cmd "review-code" {
    help "Open an interactive, pre-prompted code-review session for a review_open run"
    long_help "Opens an interactive, pre-prompted code-review session for a review_open run by launching the AI agent in the run's worktree with the code-review prompt. The session is resumable: re-running resumes the existing session, while --new-session starts fresh. The developer takes over the session to investigate, discuss, and apply fixes.\n\nSide effects: writes a code-review prompt file under the worktree's .phax-context/ and a session record under the run directory; spawns a long-lived interactive AI agent session (network I/O)."
    example "phax review-code usage-cli"
    arg "<short-name>" {
        help "Run short name, e.g. usage-cli"
    }
    flag "--new-session" {
        help "Start a fresh review session instead of resuming the existing one"
    }
    flag "--model" {
        arg "<model>"
        help "Override the model, including on resume (default: review.code.model, else claude-opus-4-8)"
    }
    flag "--effort" {
        arg "<effort>"
        help "Override the effort (low | medium | high), including on resume (default: review.code.effort, else high)"
    }
}

cmd "plans-overlap" {
    help "Report which plans can run in parallel without merge conflict"
    long_help "Reports which of two or more plans can run in parallel without a merge conflict — predicted from each plan's declared file-sets, or confirmed against a landed run's actual diff.\n\n(Predicted) Without --landed: reads each plan.md's structured form through the content-addressed extraction cache (a cold cache miss extracts once via LLM and caches the result; use --no-extract to fail on a miss instead). Unions each plan's declared phase file-sets into a per-plan footprint, intersects footprints pairwise, and reports the severity-graded conflict matrix, clean pairs, the largest fully-disjoint parallel-safe set, and a greedy wave schedule.\n\n(Confirmed) With --landed <run>: takes a run that has already produced changes and reports which of the given plans need re-adjustment because they touch a file the run actually changed. The landed run's footprint is read from its persisted global-file-reconciliation.json (the real git diff across its phases), giving actual-vs-declared impact with no false negatives.\n\nCaveats: the predicted mode reflects declared file intentions, not what agents will actually touch. Conflicts are file-level, not hunk-level — two plans editing different regions of the same file are flagged even if git would auto-merge them. Regenerated artifacts (phax.usage.kdl, docs/cli/reference.md) are a hard-conflict class.\n\nSide effects: read-only with respect to your plans; may run one LLM extraction per uncached plan.md."
    example "phax plans-overlap docs/plans/33-a.md docs/plans/35-b.md"
    example "phax plans-overlap --landed my-feature docs/plans/40-other.md"
    arg "<plan>" {
        help "Paths to two or more plan.md files"
    }
    flag "--json" {
        help "Emit the overlap result as JSON instead of a report"
    }
    flag "--no-extract" {
        help "Fail on a cache miss instead of extracting the plan.md"
    }
    flag "--landed" {
        arg "<run>"
        help "Report which of the given plans need re-adjustment after this run's actual changes"
    }
}

cmd "adjust-plan" {
    help "Open an interactive session to adjust a plan after a landed run"
    long_help "Opens an interactive, pre-prompted session to help you adjust a plan.md after a landed run has introduced drift. The session establishes which of the plan's declared files, line references, and decisions are invalidated by the landed run's actual changes, asks clarifying questions where needed, proposes concrete edits and waits for your explicit approval, and only then edits and commits the plan — all interactively within the session. The command itself mutates nothing.\n\nInput: the path to the plan.md to adjust and --landed <run> (the run whose actual changes drive the adjustment). The landed run must have a global-file-reconciliation.json (i.e. it must have reached review). Re-invocation without --new-session resumes the same session; --new-session starts a fresh one.\n\nSide effects: spawns a long-lived interactive provider session (network I/O); the session may, after developer approval, edit and commit the plan.md."
    example "phax adjust-plan docs/plans/40-foo.md --landed my-feature"
    arg "<plan>" {
        help "Path to the plan.md to adjust"
    }
    flag "--landed" {
        arg "<run>"
        required #true
        help "The landed run whose actual changes drive the adjustment"
    }
    flag "--new-session" {
        help "Start a fresh adjustment session instead of resuming"
    }
    flag "--model" {
        arg "<model>"
        help "Override the model (default: claude-opus-4-8)"
    }
    flag "--effort" {
        arg "<effort>"
        help "Override the effort (low | medium | high)"
    }
}

cmd "init" {
    help "Create phax.json and phax.schema.json in the current directory"
    long_help "Creates phax.json and phax.schema.json in the current directory. Use --force to overwrite an existing phax.json. Does not connect to any network or external service."
    example "phax init"
    example "phax init --force"
    flag "--force" {
        help "Overwrite and reconfigure an existing phax.json"
    }
    flag "--yes" {
        help "Accept detected defaults without prompting"
    }
}

cmd "report" {
    help "Open a GitHub issue from local telemetry (run semantic.jsonl or latest daily journal)"
    long_help "Creates a GitHub issue from local run telemetry. By default, uploads the full log as a secret GitHub gist and links it in the issue body. Use --no-gist to inline the log directly.\n\nSide effects: GitHub API calls — creates a GitHub issue and, unless --no-gist is set, a secret gist."
    example "phax report"
    example "phax report usage-cli"
    example "phax report usage-cli --no-gist"
    arg "[short-name]" {
        help "Run short name, e.g. usage-cli"
    }
    flag "--no-gist" {
        help "Inline the full log in the issue body instead of creating a secret gist"
    }
}

cmd "completions" {
    help "Generate a shell completion script (zsh, bash, fish, nu, powershell). Requires the usage CLI."
    arg "<shell>" {
        help "Shell to generate completions for (zsh, bash, fish, nu, powershell)"
    }
}

cmd "resume" {
    help "Resume a run from its next pending phase"
    long_help "Picks up a run from its next pending phase, re-entering the same execution loop as phax run. Prompts for confirmation before proceeding unless --yes is set.\n\nSide effects: creates worktrees, commits files, writes to ~/.phax/runs/."
    example "phax resume usage-cli"
    example "phax resume usage-cli --yes"
    arg "<short-name>" {
        help "Run short name, e.g. usage-cli"
    }
    flag "--yes -y" {
        help "Proceed without confirmation"
    }
    flag "--verbose" {
        help "Print human-readable progress and system events"
    }
    flag "--trace" {
        help "Write structured JSONL trace events to the run folder"
    }
    flag "--provider-priority" {
        arg "<list>"
        help "Comma-separated provider priority override (e.g. mistral-vibe,claude-code)"
    }
}

cmd "reset-phase" {
    help "Reset a stuck or failed phase so phax resume re-runs it from scratch"
    arg "<short-name>" {
        help "Run short name, e.g. usage-cli"
    }
    arg "[phase-id]" {
        help "Phase identifier to reset, e.g. phase-02; defaults to the stuck phase"
    }
    flag "--yes -y" {
        help "Proceed without confirmation (removes the worktree and branch)"
    }
    flag "--verbose" {
        help "Print human-readable progress and system events"
    }
    flag "--trace" {
        help "Write structured JSONL trace events to the run folder"
    }
}

cmd "agent" {
    help "Inspect and manage model routing and provider configuration"

    cmd "models" {
        help "Print the routing table and provider priority"
    }

    cmd "resolve" {
        help "Show how a model+effort request resolves to a provider and concrete model"
        flag "--model" {
            arg "<id>"
            required #true
            help "Requested model id (e.g. claude-sonnet-5)"
        }
        flag "--effort" {
            arg "<level>"
            required #true
            help "Effort/thinking level (none|off|low|medium|high|xhigh|max|ultracode)"
        }
        flag "--json" {
            help "Output the resolution as JSON"
        }
    }

    cmd "probe" {
        help "Check which provider executables are available on PATH; never throws on an unavailable provider"
    }

    cmd "setup" {
        help "Set up provider integrations"

        cmd "mistral-vibe" {
            help "Append PHAX-owned Mistral Vibe model aliases to ~/.vibe/config.toml (append-only, atomic)"
            flag "--dry-run" {
                help "Preview what would be appended without writing anything"
            }
            flag "--install-model-aliases" {
                help "Actually append the missing aliases and write the backup"
            }
        }

        cmd "providers" {
            help "Reconcile ~/.phax/providers.json enabled flags from live executable probes (dry-run by default)"
            flag "--write" {
                help "Persist the reconciled config (writes a timestamped backup first)"
            }
            flag "--prune" {
                help "Also disable providers whose executable is unavailable"
            }
            flag "--with-routing" {
                help "Scaffold ~/.phax/model-routing.json from defaults when absent (never overwrites)"
            }
        }
    }
}

cmd "security" {
    help "Security-related commands"
    flag "--verbose" {
        help "Print human-readable progress and system events"
    }
    flag "--trace" {
        help "Write structured JSONL trace events to the run folder"
    }

    cmd "status" {
        help "Show provider security capabilities and availability"
        flag "--verbose" {
            help "Print human-readable progress and system events"
        }
        flag "--trace" {
            help "Write structured JSONL trace events to the run folder"
        }
    }
}

cmd "skills" {
    help "Manage PHAX skills"

    cmd "install" {
        help "Install bundled PHAX skills into an agent's native skill directory"
        arg "[skill]" {
            help "Skill to install (phax-planning|phax-cli|phax-spec); installs all skills when omitted"
        }
        flag "--target" {
            arg "<target>"
            required #true
            help "Agent target (claude|codex|agent)"
        }
        flag "--scope" {
            arg "<scope>"
            default "project"
            help "Installation scope (project|user)"
        }
    }
}

cmd "schema" {
    help "Manage the local phax.schema.json"

    cmd "upgrade" {
        help "Regenerate phax.schema.json from the installed binary's config contract; never modifies phax.json"
    }
}
