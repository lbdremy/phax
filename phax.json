{
  "$schema": "https://phax.dev/schema/phax.schema.json",
  "version": 1,
  "project": { "name": "phax", "type": "single-package" },
  "state": { "root": "~/.phax" },
  "editor": { "command": "zed" },
  "agent": {
    "maxFixAttempts": 1
  },
  "security": {
    "filesystem": {
      "allowWrite": ["~/.phax"]
    }
  },
  "commands": {
    "setup": ["pnpm install"],
    "cleanup": ["rm -rf node_modules"]
  },
  "gateProfiles": {
    "fast": ["pnpm typecheck", "pnpm test:unit"],
    "full": [
      "pnpm typecheck",
      "pnpm lint",
      "pnpm format:check",
      "pnpm knip",
      "pnpm test",
      "pnpm audit:architecture",
      "pnpm build"
    ]
  }
}
