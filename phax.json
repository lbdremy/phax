{
  "$schema": "./phax.schema.json",
  "version": 1,
  "project": { "name": "phax", "type": "single-package" },
  "state": { "root": "~/.phax" },
  "agent": {
    "maxFixAttempts": 1
  },
  "security": {
    "filesystem": {
      "allowWrite": ["~/.phax"]
    },
    "agentCommands": ["deno", "ctx7", "usage"]
  },
  "publish": {
    "enabled": true,
    "remote": "origin",
    "provider": "github",
    "pushBranch": true,
    "createPullRequest": true,
    "baseBranch": "main"
  },
  "commands": {
    "setup": ["pnpm install"],
    "cleanup": ["rm -rf node_modules"]
  },
  "gateProfiles": {
    "fast": ["pnpm format", "pnpm typecheck", "pnpm test:unit"],
    "full": [
      "pnpm format",
      "pnpm typecheck",
      "pnpm lint",
      "pnpm format:check",
      "pnpm knip",
      "pnpm test",
      "pnpm audit:architecture",
      "pnpm build",
      "pnpm deno:smoke",
      "pnpm deno:smoke-binary"
    ]
  }
}
