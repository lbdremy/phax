{
  "name": "phax",
  "version": "0.4.0",
  "description": "Deterministic local CLI that drives AI Coding agent through isolated, gated phases",
  "license": "Apache-2.0",
  "bin": {
    "phax": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "phax.usage.kdl",
    ".claude/skills/phax-planning",
    ".claude/skills/phax-cli",
    ".claude/skills/phax-spec"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli/main.ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:type": "tsc --noEmit -p tsconfig.test.json",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "knip": "knip",
    "gen:usage-spec": "tsx scripts/generate-usage-spec.ts",
    "docs:cli": "tsx scripts/docs-cli.ts",
    "audit:architecture": "vitest run tests/unit/architecturalGuards.test.ts",
    "check:full": "npm run typecheck && npm run test:unit && npm run test:integration && npm run test:type && npm run lint && npm run format:check && npm run audit:architecture && npm run knip",
    "test:e2e:real": "vitest run --config vitest.e2e.config.ts",
    "deno:smoke": "deno run --sloppy-imports --allow-read --allow-env --allow-sys --allow-run src/cli/main.ts --version",
    "deno:check": "deno check src/cli/main.ts",
    "deno:compile": "deno task compile",
    "deno:build-binaries": "deno run --allow-read --allow-write --allow-run --allow-env scripts/build-binaries.ts",
    "deno:smoke-binary": "sh scripts/smoke-binary.sh",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.106.0",
    "commander": "^12.0.0",
    "effect": "^3.14.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-to-string": "^4.0.0"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.9.3",
    "esbuild": "^0.28.0",
    "knip": "^6.12.2",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.15.1"
}
