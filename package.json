{
  "name": "phax",
  "version": "0.1.0",
  "description": "Deterministic local CLI that drives Claude Code through isolated, gated phases",
  "type": "module",
  "bin": {
    "phax": "./dist/cli/main.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli/main.ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:type": "tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.106.0",
    "commander": "^12.0.0",
    "effect": "^3.14.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
